# glue.env - local, per-machine glue config. Copy to glue.env (gitignored) and edit.
#
# Simple KEY=VALUE, no shell expansion (parsed by both shell and Python).

# Goggle console serial port (the Pico UART bridge -if00 interface). Prefer the stable
# by-id path so it survives replug and ttyACM renumbering:
#   ML_SERIAL=/dev/serial/by-id/usb-Raspberry_Pi_Pico_..._-if00
# A bare /dev/ttyACMx works too, but can change across replugs. Find yours with:
#   ls /dev/serial/by-id/
ML_SERIAL=
